# Endpoints
ELASTICSEARCH_URL=
KIBANA_URL=

# Authentication (use either API Key or both of Username and Password)
ELASTICSEARCH_API_KEY=
#ELASTICSEARCH_USERNAME=
#ELASTICSEARCH_PASSWORD=


####  Optional advanced settings  ##############################################

# Where `index` keeps its persistent repo clones (default: ~/.cache/sourcerer)
#SOURCERER_CACHE_DIR=~/.cache/sourcerer

# Bulk send tuning. In-flight client memory scales roughly as
# (ELASTICSEARCH_BULK_THREADS + ELASTICSEARCH_BULK_QUEUE_SIZE) * ELASTICSEARCH_BULK_CHUNK_SIZE * avg_doc_bytes.
# Lower the chunk size for small/Serverless clusters that return 429s.
#ELASTICSEARCH_BULK_CHUNK_SIZE=5000          # docs per bulk chunk (default: 5000)
#ELASTICSEARCH_BULK_THREADS=8                # parallel bulk sender threads (default: 8)
#ELASTICSEARCH_BULK_MAX_BYTES=10485760       # max bytes per bulk request (default: 10485760 [10 MB])
#ELASTICSEARCH_BULK_QUEUE_SIZE=16            # chunks buffered ahead of senders (default: ES_BULK_THREADS * 2)

# Document generation (the throughput ceiling): file read/decode/hash farmed out to worker processes.
#ELASTICSEARCH_INDEX_WORKERS=                # worker processes (default: CPU count, else 4)
#ELASTICSEARCH_INDEX_WORKER_CHUNKSIZE=8      # file paths dispatched per IPC round-trip (default: 8)

# Batch concurrency for the config-driven (`--config`) path.
#INDEX_REPO_CONCURRENCY=2         # (org, repo) clones processed concurrently (default: 2)
#RESOLVE_CONCURRENCY=16           # concurrent `git ls-remote` calls during planning (default: 16)