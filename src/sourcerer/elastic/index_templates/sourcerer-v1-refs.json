{
  "_meta": {
    "description": "sourcerer-v1-refs"
  },
  "index_patterns": [
    "sourcerer-v1-refs*"
  ],
  "template": {
    "settings": {
      "index": {
        "sort": {
          "field": [
            "git.org",
            "git.repo",
            "git.ref"
          ],
          "order": [
            "asc",
            "asc",
            "asc"
          ]
        }
      }
    },
    "mappings": {
      "properties": {
        "git": {
          "properties": {
            "org": {
              "type": "keyword",
              "normalizer": "lowercase"
            },
            "repo": {
              "type": "keyword",
              "normalizer": "lowercase"
            },
            "ref": {
              "type": "keyword",
              "normalizer": "lowercase"
            },
            "ref_type": {
              "type": "keyword",
              "normalizer": "lowercase"
            },
            "commit": {
              "type": "keyword",
              "normalizer": "lowercase"
            },
            "commit_date": {
              "type": "date"
            }
          }
        },
        "status": {
          "type": "keyword",
          "normalizer": "lowercase"
        },
        "files_count": {
          "type": "long"
        },
        "lines_count": {
          "type": "long"
        },
        "indexed_at": {
          "type": "date"
        }
      }
    }
  }
}